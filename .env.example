# ─── Client-side env vars (Vite) ──────────────────────────────────
# These are exposed to the browser via import.meta.env.VITE_*
# NEVER put secrets (service-role keys, Stripe secret keys, API keys)
# in this file — only public-safe values.

# Supabase Configuration
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# App Configuration
VITE_APP_NAME="Remote Legal Case Orchestrator"
VITE_APP_ENV=development

# Stripe — Publishable key only (safe to expose in frontend)
# Get from: Stripe Dashboard → Developers → API Keys → Publishable key
# Note: Secret key goes in Supabase Edge Function secrets, NOT here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Monitoring (optional, production-only) ──────────────────────
# Sentry error tracking — get DSN from https://sentry.io → Settings → Client Keys
# Only activates when VITE_APP_ENV=production
# VITE_SENTRY_DSN=https://your-key@sentry.io/project-id

# Plausible Analytics — set to your domain (no cookies, no PII)
# Get from https://plausible.io → Site Settings
# Only activates when VITE_APP_ENV=production
# VITE_PLAUSIBLE_DOMAIN=remote-legal-uae.vercel.app


# ─── Server-side secrets (Supabase Edge Functions) ───────────────
# These do NOT go in .env.local — set them via the Supabase CLI:
#
#   supabase secrets set \
#     SUPABASE_URL=$VITE_SUPABASE_URL \
#     SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY \
#     SUPABASE_SERVICE_ROLE_KEY=... \
#     OPENAI_API_KEY=sk-... \
#     STRIPE_SECRET_KEY=sk_live_... \
#     STRIPE_WEBHOOK_SECRET=whsec_... \
#     RESEND_API_KEY=re_... \
#     FROM_EMAIL=noreply@yourdomain.com \
#     ALLOWED_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com
#
# Required for all edge functions:
#   SUPABASE_URL                — same as VITE_SUPABASE_URL
#   SUPABASE_ANON_KEY           — same as VITE_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY   — Dashboard → Settings → API → service_role
#
# Required for analyze-case + analyze-document:
#   OPENAI_API_KEY              — https://platform.openai.com/api-keys
#
# Required for create-checkout + stripe-webhook:
#   STRIPE_SECRET_KEY           — Dashboard → Developers → API Keys → Secret key
#   STRIPE_WEBHOOK_SECRET       — Dashboard → Developers → Webhooks → Signing secret
#
# Required for send-emails:
#   RESEND_API_KEY              — https://resend.com/api-keys
#   FROM_EMAIL                  — verified sender, e.g. noreply@yourdomain.com
#
# Required for CORS allowlist on ALL edge functions (Phase 0 security fix):
#   ALLOWED_ORIGINS             — comma-separated list of allowed browser origins
#                                 e.g. https://yourdomain.com,https://staging.yourdomain.com
#                                 Localhost dev origins are always allowed automatically.
