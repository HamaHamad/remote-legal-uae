# Supabase Configuration
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# App Configuration
VITE_APP_NAME="Remote Legal Case Orchestrator"
VITE_APP_ENV=development

# Stripe — Publishable key only (safe to expose in frontend)
# Get from: Stripe Dashboard → Developers → API Keys → Publishable key
# Note: Secret key goes in Supabase Edge Function secrets, NOT here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
